{
  agents: {
    defaults: {
      workspace: "/app/workspace",
      model: {
        primary: "google/gemini-3-flash-preview",
      },
    },
  },

  channels: {
    telegram: {
      enabled: true,
      botToken: "${TELEGRAM_BOT_TOKEN}",
      dmPolicy: "allowlist",
      allowFrom: [913874732],
      groupPolicy: "disabled",
    },
  },

  skills: {
    load: {
      extraDirs: ["/app/skills"],
    },
    entries: {
      "polymarket-market-research": {
        enabled: true,
        env: {
          POLYMARKET_GAMMA_API_URL: "https://gamma-api.polymarket.com",
        },
      },
      "polymarket-trade": {
        enabled: true,
      },
      "odds-comparison": {
        enabled: true,
      },
    },
  },

  hooks: {
    enabled: true,
    token: "${OPENCLAW_HOOKS_TOKEN}",
    path: "/hooks",
  },

  gateway: {
    port: 18789,
    bind: "lan",
    mode: "local",
    auth: {
      mode: "token",
      token: "${OPENCLAW_GATEWAY_TOKEN}",
    },
  },

  session: {
    dmScope: "per-channel-peer",
    reset: {
      mode: "idle",
      idleMinutes: 120,
    },
  },
}
