{
  // Clawk agent configuration
  // Mounted at ~/.openclaw/openclaw.json inside the container

  agents: {
    defaults: {
      workspace: "/app/workspace",
      model: {
        primary: "google/gemini-3-flash-preview",
        fallbacks: ["google/gemini-3-pro-preview"],
      },
    },
  },

  channels: {
    telegram: {
      enabled: true,
      botToken: "${TELEGRAM_BOT_TOKEN}",
      dmPolicy: "allowlist",
      allowFrom: ["${TELEGRAM_ALLOWED_USER_ID}"],
    },
  },

  skills: {
    load: {
      extraDirs: ["/app/skills"],
    },
    entries: {
      "polymarket-market-research": {
        enabled: true,
        env: {
          POLYMARKET_GAMMA_API_URL: "https://gamma-api.polymarket.com",
        },
      },
      "polymarket-trade": {
        enabled: true,
      },
    },
  },

  hooks: {
    enabled: true,
    token: "${OPENCLAW_HOOKS_TOKEN}",
    path: "/hooks",
  },

  gateway: {
    port: 18789,
    bind: "0.0.0.0",
    auth: {
      mode: "token",
      token: "${OPENCLAW_GATEWAY_TOKEN}",
    },
  },

  session: {
    dmScope: "per-channel-peer",
    reset: {
      mode: "idle",
      idleMinutes: 120,
    },
  },
}
